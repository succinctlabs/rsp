SP1_PROVER=
HTTP_RPC_URL=
WS_RPC_URL=
# Leave ETH_PROOFS_ENDPOINT and ETH_PROOFS_API_TOKEN empty to run locally without submitting
# to ethproofs (execution, proving and metrics still run).
ETH_PROOFS_ENDPOINT=
ETH_PROOFS_API_TOKEN=
PAGER_DUTY_INTEGRATION_KEY=
# Address to serve internal Prometheus metrics on. Leave empty to disable. The port must match
# the mapping in docker-compose.yml when running via compose.
METRICS_ADDR=0.0.0.0:9000

